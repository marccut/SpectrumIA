# ============================================================================
# SpectrumIA - Production Environment Variables
# ============================================================================
#
# IMPORTANT: Copy this file to .env.production and fill in actual values
# NEVER commit .env.production to git - it contains sensitive credentials
#
# ============================================================================

# SUPABASE CONFIGURATION
# ============================================================================
# Get these values from your Supabase project dashboard:
# https://app.supabase.com -> Settings -> API

# Your Supabase project URL (https://your-project.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key (for client-side operations)
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (for server-side operations with elevated privileges)
# IMPORTANT: Keep this secret! Never expose in client-facing code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct PostgreSQL connection URL (optional, for direct database access)
# Format: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# ============================================================================
# AUTHENTICATION CONFIGURATION
# ============================================================================

# JWT Secret (from Supabase project settings)
# Used to verify JWT tokens in production
JWT_SECRET=your-jwt-secret-here

# JWT token expiration times
JWT_EXPIRES_IN=3600                    # Access token: 1 hour (seconds)
JWT_REFRESH_EXPIRES_IN=2592000         # Refresh token: 30 days (seconds)

# Email verification settings
EMAIL_VERIFICATION_ENABLED=true
EMAIL_VERIFICATION_EXPIRATION_HOURS=24

# Password reset settings
PASSWORD_RESET_ENABLED=true
PASSWORD_RESET_EXPIRATION_HOURS=24

# ============================================================================
# STREAMLIT CONFIGURATION
# ============================================================================

# Server configuration
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Authentication
STREAMLIT_CLIENT_TOOLBARMODE=viewer

# Session management
SESSION_TIMEOUT_MINUTES=60
MAX_CONCURRENT_SESSIONS=100

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment
ENVIRONMENT=production
APP_DEBUG=false
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# Eye-Tracking Configuration
GAZE_CALIBRATION_POINTS=9
GAZE_SMOOTHING_FACTOR=0.7
MIN_FIXATION_DURATION_MS=100

# Assessment Configuration
ASSESSMENT_VIDEO_PATH=/app/stimuli/videos/
NUM_AOI_REGIONS=4
MIN_SAMPLES_PER_STIMULUS=30

# Feature Extraction
EXTRACT_GAZE_DYNAMICS=True
EXTRACT_TEMPORAL_METRICS=True
EXTRACT_SCANPATH_ENTROPY=True

# ============================================================================
# DATA RETENTION & CLEANUP
# ============================================================================

# Session timeout and data retention
SESSION_TIMEOUT_MINUTES=60
CALIBRATION_RETENTION_DAYS=30
ASSESSMENT_RETENTION_DAYS=365
RESULTS_RETENTION_DAYS=90

# Automatic cleanup
ENABLE_AUTO_CLEANUP=true
CLEANUP_JOB_HOUR=2                     # Run cleanup at 2 AM UTC

# ============================================================================
# MONITORING & LOGGING
# ============================================================================

# Logging configuration
LOG_LEVEL=INFO
LOG_FORMAT=json                        # json for structured logging
LOG_FILE=/var/log/spectrumia/app.log
LOG_MAX_BYTES=10485760                 # 10MB file rotation
LOG_BACKUP_COUNT=5

# Performance monitoring
ENABLE_METRICS=true
METRICS_PORT=8000
METRICS_NAMESPACE=spectrumia

# ============================================================================
# SECURITY
# ============================================================================

# CORS configuration (for API access from other domains)
CORS_ORIGINS=https://your-domain.com
CORS_ALLOW_CREDENTIALS=true
CORS_EXPOSE_HEADERS=content-length,x-json-response

# Rate limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# API key for external services
API_KEY_PREFIX=sk_prod_

# ============================================================================
# EXTERNAL SERVICES (Optional)
# ============================================================================

# Error reporting (Sentry)
SENTRY_DSN=https://key@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_PROVIDER=custom              # custom, segment, mixpanel, etc

# Email service (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@spectrumia.ai
SMTP_FROM_NAME=SpectrumIA

# ============================================================================
# DATABASE PERFORMANCE
# ============================================================================

# Connection pooling
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
DB_POOL_TIMEOUT_SECONDS=30

# Query performance
DB_QUERY_TIMEOUT_SECONDS=30
DB_SLOW_QUERY_THRESHOLD_MS=1000

# ============================================================================
# BACKUP & DISASTER RECOVERY
# ============================================================================

# Enable automated backups
ENABLE_AUTOMATED_BACKUPS=true
BACKUP_FREQUENCY=daily                 # daily, weekly, or custom
BACKUP_RETENTION_DAYS=30

# Backup storage (S3 or other)
BACKUP_STORAGE_TYPE=supabase            # supabase, s3, gcs, etc
BACKUP_ENCRYPTION_ENABLED=true

# ============================================================================
# DEPLOYMENT
# ============================================================================

# Docker configuration
DOCKER_IMAGE_REGISTRY=docker.io
DOCKER_IMAGE_NAME=spectrumia
DOCKER_IMAGE_TAG=latest

# Health check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL_SECONDS=30

# ============================================================================
# NOTES FOR PRODUCTION DEPLOYMENT
# ============================================================================
#
# 1. NEVER commit this file to git
# 2. Use a secure secrets manager (AWS Secrets Manager, HashiCorp Vault, etc)
# 3. Rotate credentials regularly (at least quarterly)
# 4. Restrict access to this file to authorized personnel only
# 5. Enable database backups before going live
# 6. Test disaster recovery procedures
# 7. Monitor all services continuously
# 8. Set up alerting for critical metrics
# 9. Document all configuration changes
# 10. Maintain an audit log of access and changes
#
# ============================================================================
