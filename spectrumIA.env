# ============================================================================
# SpectrumIA Environment Configuration
#
# INSTRUCÇÕES:
# 1. Copie este arquivo e renomeie para ".env" (remova ".example")
# 2. Preencha com suas credenciais do Supabase
# 3. NUNCA compartilhe o arquivo .env com dados reais!
# ============================================================================

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================

# URL do seu projeto Supabase
# Encontre em: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://supabase.com/dashboard/project/eeqtgpbnqlgkgwtgpiof/settings/jwt

# Chave anônima do Supabase (uso cliente)
# Encontre em: Supabase Dashboard → Settings → API → anon public
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVlcXRncGJucWxna2d3dGdwaW9mIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ1ODgxMjMsImV4cCI6MjA5MDE2NDEyM30.JWf12W8dFvtW23bWB5ARl7arm5GJQB-TVjSYwQ04PGk

# Chave de Service Role (uso servidor/backend)
# Encontre em: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVlcXRncGJucWxna2d3dGdwaW9mIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NDU4ODEyMywiZXhwIjoyMDkwMTY0MTIzfQ.K7WZxpAegFgatGaRSKKgB3gXFSaxUGYQP9jSUkFdAaA

# String de conexão do banco PostgreSQL
# Encontre em: Supabase Dashboard → Database Management → Settings → Connection string
# Formato: postgresql://usuario:senha@host:porta/banco
DATABASE_URL=postgresql://postgres:T?5MX!7y%Z2V@spectrumIA.supabase.co:5432/postgres

# ============================================================================
# JWT CONFIGURATION (para autenticação)
# ============================================================================

# Secret JWT do Supabase (para validar tokens)
# Encontre em: Supabase Dashboard → Settings → API → JWT Secret
JWT_SECRET=seu-jwt-secret-aqui

# Algoritmo de JWT
JWT_ALGORITHM=HS256

# Tempo de expiração do token (em segundos)
JWT_EXPIRATION=3600

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Ambiente (development, staging, production)
ENV=development

# Port para a aplicação Streamlit
STREAMLIT_PORT=8501

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Ativar modo debug
DEBUG=true

# Ativar logs detalhados
VERBOSE_LOGGING=false
